# HemoGrid — Environment Configuration
#
# Copy this file to .env for local overrides:
#   cp .env.example .env
#
# The app works out of the box without a .env file — all values below are
# the hardcoded defaults used in local development.
#
# IMPORTANT FOR AWS / PRODUCTION DEPLOYMENT:
#   These values are currently hardcoded in main.py and the engine modules.
#   Before deploying, update those files to read from os.environ so that
#   the variables below actually take effect.
#   Relevant files to update:
#     main.py          — PORT, DATA_DIR, TODAY
#     engine/match.py  — DATA_DIR, TODAY
#     engine/state.py  — DATA_DIR (DB_PATH), TODAY
#     engine/forecast.py — DATA_DIR, TODAY
#     engine/ai.py     — OLLAMA_URL


# ── AI (optional) ──────────────────────────────────────────────────────────────
# URL of the Ollama /api/generate endpoint.
# Set to empty string to disable AI explanations entirely (fails silently).
OLLAMA_URL=http://localhost:11434/api/generate

# Ollama model to use for explanations and log summaries.
OLLAMA_MODEL=phi3


# ── FastAPI server ─────────────────────────────────────────────────────────────
# Host and port for the uvicorn server.
HOST=0.0.0.0
PORT=8000


# ── Data paths ─────────────────────────────────────────────────────────────────
# Path to the canonical CSV dataset directory (relative to project root,
# or absolute for containerised / cloud deployments).
DATA_DIR=./data/build

# Path to the mutable SQLite simulation database.
# This file is created automatically on first startup; do not commit it.
DB_PATH=./data/working_sim.db


# ── Demo date ──────────────────────────────────────────────────────────────────
# The dataset is intentionally forward-dated. Keep this value fixed to
# match the synthetic data unless you have rebuilt the dataset with a
# different reference date.
TODAY=2026-06-06
